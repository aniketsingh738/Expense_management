<mvc:View
    controllerName="com.expensemanagement.expensemanagement.controller.Pending"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page title="{i18n>pendingApprovalPageTitle}">
        <content>
            <Table
                id="pendingTable"
                items="{ path: '/Requests'}"
                growing="true"
                growingScrollToLoad="true"
                class="sapUiResponsiveMargin"
            >
                <!-- Columns -->
                <columns>
                    <!-- Main Info -->
                    <Column width="16em">
                        <Text text="{i18n>PnPgrequest}" />
                    </Column>

                    <!-- Travel Info -->
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>PnPgtravelInfo}" />
                    </Column>

                    <!-- Amount -->
                    <Column
                        hAlign="{= ${usetModel>/role} ==='APPROVER'?'End':'Start'}"
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>PnPgamount}" />
                    </Column>

                    <!-- Actions -->
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                        visible="{= ${userModel>/role} === 'APPROVER' }"
                    >
                        <Text text="{i18n>PnPgactions}" />
                    </Column>
                </columns>

                <!-- Items -->
                <items>
                    <ColumnListItem vAlign="Middle">
                        <cells>
                            <!--Main Info -->
                            <ObjectIdentifier
                                title="{destination}"
                                text="{i18n>PnPgempId}: {empId}"
                            />

                            <!-- Travel & Purpose -->
                            <VBox>
                                <!-- Travel Type -->
                                <Text text="{travelType}" />

                                <!-- Dates -->
                                <HBox
                                    class="sapUiTinyMarginTop"
                                    wrap="Wrap"
                                >
                                    <Text text="{startDate}" />
                                    <Text
                                        text=" - "
                                        class="sapUiTinyMarginBegin sapUiTinyMarginEnd"
                                    />
                                    <Text text="{endDate}" />
                                </HBox>

                                <!--Purpose -->
                                <Text
                                    text="{purpose}"
                                    class="sapUiTinyMarginTop"
                                    wrapping="true"
                                />
                            </VBox>

                            <!--Amount -->
                            <ObjectNumber
                                number="{amount}"
                                unit="{i18n>PnPgcurrencyUnit}"
                            />

                            <!--Actions -->
                            <HBox
                                visible="{= ${userModel>/role} === 'APPROVER' }"
                                justifyContent="Start"
                                renderType="Bare"
                            >
                                <Button
                                    icon="sap-icon://accept"
                                    type="Accept"
                                    press="onApprove"
                                    tooltip="{i18n>PnPgapproveText}"
                                />
                                <Button
                                    icon="sap-icon://decline"
                                    type="Reject"
                                    press="onReject"
                                    class="sapUiTinyMarginBegin"
                                    tooltip="{i18n>PnPgrejectText}"
                                />
                            </HBox>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
