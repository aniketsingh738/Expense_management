<mvc:View
    controllerName="com.expensemanagement.expensemanagement.controller.Finance"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.ui.layout.form"
>
    <Page title="{i18n>FinancePageTitile}">
        <!-- Filter Section -->
        <VBox class="sapUiSmallMargin">
            <HBox
                justifyContent="SpaceBetween"
                wrap="Wrap"
            >
                <!-- Employee ID -->
                <VBox>
                    <Label text="{i18n>FnPgsearchEmployeeIdLb}" />
                    <Input
                        id="empIdInput"
                        placeholder="{i18n>FnPgsearchEmployeeIdPlHd}"
                        width="200px"
                    />
                </VBox>

                <!-- Date Range -->
                <VBox>
                    <Label text="{i18n>FnPgdateRange}" />
                    <DateRangeSelection
                        id="dateRange"
                        width="250px"
                    />
                </VBox>

                <!-- Amount -->
                <VBox>
                    <Label text="{i18n>FnPgamountLabel}" />
                    <Input
                        id="amountInput"
                        type="Number"
                        placeholder="{i18n>FnPgamountPlaceHd}"
                        width="200px"
                    />
                </VBox>

                <!-- Filter Button -->
                <VBox justifyContent="End">
                    <HBox>
                        <Button
                            text="{i18n>FnPgapplyFilterBtn}"
                            press="onFilter"
                        />

                        <!-- Clear Button -->
                        <Button
                            text="{i18n>FnPgclearFilterBtn}"
                            type="Transparent"
                            press="onClearFilters"
                            class="sapUiTinyMarginBegin"
                        />
                    </HBox>
                </VBox>
            </HBox>
        </VBox>

        <!-- Table -->

        <Table
            id="financeTable"
            items="{ path: '/Requests'}"
            growing="true"
            growingScrollToLoad="true"
            class="sapUiResponsiveMargin"
        >
            <columns>
                <Column width="18em">
                    <Text text="{i18n>FnPgreqInfo}" />
                </Column>
                <Column
                    minScreenWidth="Tablet"
                    demandPopin="true"
                >
                    <Text text="{i18n>FnPgtravelDetails}" />
                </Column>
                <Column hAlign="End">
                    <Text text="{i18n>FnPgamount}" />
                </Column>
                <Column>
                    <Text text="{i18n>FnPgstatus}" />
                </Column>
            </columns>

            <items>
                <ColumnListItem
                    type="Active"
                    press="onItemPress"
                    vAlign="Middle"
                >
                    <cells>
                        <!-- Main Info -->
                        <ObjectIdentifier
                            title="{destination}"
                            text="{i18n>FnPgempId}: {empId}"
                        />

                        <!-- Secondary Info -->
                        <VBox>
                            <Text text="{travelType}" />
                            <Text
                                text="{purpose}"
                                class="sapUiTinyMarginTop"
                            />
                        </VBox>

                        <!--Amount -->
                        <ObjectNumber
                            number="{amount}"
                            unit="{i18n>FnPgcurrencyUnit}"
                        />

                        <!-- Status -->
                        <ObjectStatus
                            text="{status}"
                            state="{ path: 'status', formatter: '.formatter.statusText' }"
                        />
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Page>
</mvc:View>
