<mvc:View
    controllerName="com.expensemanagement.expensemanagement.controller.List"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Page title="{i18n>requestStatusPageTitle}">
        <content>

            <!--  Filter Bar -->
            <Toolbar class="sapUiSmallMarginBottom">
                <SearchField
                 id="searchField"
                    width="50%"
                    liveChange="onSearch"
                    placeholder="{i18n>LiPgsearchBarPlHolder}"
                />
                <ToolbarSpacer />
                <Select id="statusSelect" change="onFilterChange" selectedKey="ALL">
                    <items>
                        <core:Item key="ALL" text="{i18n>LiPgselectBarAll}" />
                        <core:Item key="Approved" text="{i18n>LiPgselectBarApproved}" />
                        <core:Item key="Rejected" text="{i18n>LiPgselectBarRejected}" />
                    </items>
                </Select>
            </Toolbar>

            <!--Table -->
            <Table
                id="statusTable"
                items="{ path: '/Requests'}"
                growing="true"
                growingScrollToLoad="true"
                class="sapUiResponsiveMargin"
            >
                <columns>
                    <Column width="18em">
                        <Text text="{i18n>LiPgrequestInfo}"/>
                    </Column>
                    <Column minScreenWidth="Tablet" demandPopin="true">
                        <Text text="{i18n>LiPgtravelDetails}"/>
                    </Column>
                    <Column hAlign="End">
                        <Text text="{i18n>LiPgamount}"/>
                    </Column>
                    <Column>
                        <Text text="{i18n>LiPgstatus}"/>
                    </Column>
                </columns>

                <items>
                    <ColumnListItem
                        type="Active"
                        press="onItemPress"
                        vAlign="Middle"
                    >
                        <cells>

                            <!-- Main Info -->
                            <ObjectIdentifier
                                title="{destination}"
                                text="{i18n>LiPgempId}: {empId}"
                            />

                            <!--  Secondary Info -->
                            <VBox>
                                <Text text="{travelType}" />
                                <Text text="{purpose}" class="sapUiTinyMarginTop"/>
                            </VBox>

                            <!-- Amount -->
                            <ObjectNumber
                                number="{amount}"
                                unit="{i18n>LiPgcurrencyUnit}"
                            />

                            <!-- Status -->
                            <ObjectStatus
                                text="{status}"
                                state="{ path: 'status', formatter: '.formatter.statusText' }"
                            />

                        </cells>
                    </ColumnListItem>
                </items>
            </Table>

        </content>
    </Page>
</mvc:View>