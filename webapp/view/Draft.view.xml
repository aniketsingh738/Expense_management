<mvc:View
    controllerName="com.expensemanagement.expensemanagement.controller.Draft"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page title="{i18n>draftPageTitle}" class="bluePageTitle">
        <content>
            <Table
                id="draftTable"
                items="{
          path: '/Requests'
         
        }"
                growing="true"
                growingScrollToLoad="true"
                class="sapUiResponsiveMargin"
            >
                <!-- Columns -->
                <columns>
                    
                    <Column width="10em">
                        <Text text="{i18n>DrPgempId}" />
                    </Column>

                    <Column>
                        <Text text="{i18n>DrPgtype}" />
                    </Column>

                    
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>DrPgstartDate}" />
                    </Column>

                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>DrPgendDate}" />
                    </Column>

                   
                    <Column
                        minScreenWidth="Tablet"
                        demandPopin="true"
                    >
                        <Text text="{i18n>DrPgdestination}" />
                    </Column>

                 
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                        hAlign="Begin"
                    >
                        <Text text="{i18n>DrPgamount}" />
                    </Column>

                    
                    <Column
                        minScreenWidth="Desktop"
                        demandPopin="true"
                        hAlign="Begin"
                    >
                        <Text text="{i18n>DrPgpurpose}" />
                    </Column>

                 
                    <Column
                        hAlign="Begin"
                     
                        class="sapUiSmallMarginEnd"
                    >
                        <Text text="{i18n>DrPgactions}" />
                    </Column>
                </columns>
                <!-- Rows -->
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{empId}" />
                            <Text text="{travelType}" />

                            <Text text="{startDate}" />
                            <Text text="{endDate}" />

                            <Text text="{destination}" />

                            <ObjectNumber
                                number="{amount}"
                                unit="{i18n>DrPgcurrencyUnit}"
                            />

                            <Text text="{purpose}" />

                            <!-- Actions -->
                            <MenuButton icon="sap-icon://overflow">
                                <menu>
                                    <Menu>
                                        <MenuItem
                                            icon="sap-icon://edit"
                                            press="onEdit"
                                            text="{i18n>DrPgeditBtnText}"
                                        />
                                        <MenuItem
                                            icon="sap-icon://delete"
                                            press="onDelete"
                                            text="{i18n>DrPgdeleteBtnText}"
                                        />
                                        <MenuItem
                                            icon="sap-icon://paper-plane"
                                            press="onSubmit"
                                            text="{i18n>DrPgsubmitBtntext}"
                                        />
                                    </Menu>
                                </menu>
                            </MenuButton>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
    </Page>
</mvc:View>
