<mvc:View
    controllerName="com.expensemanagement.expensemanagement.controller.Object"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page title="{i18n>objectPageHeader}" showNavButton="true" navButtonPress="onNavBack">
        <content>

            <ObjectHeader
                title="{destination}"
                number="{amount}"
                numberUnit="{i18n>ObPgcurrencyUnit}"
            >
                <attributes>
                    <ObjectAttribute text="{i18n>ObPgemployeeId}: {empId}" />
                    <ObjectAttribute text="{i18n>ObPgtype}: {travelType}" />
                    <ObjectAttribute text="{i18n>ObPgpurpose}: {purpose}" />
                </attributes>
                <statuses>
                    <ObjectStatus
                        text="{status}"
                        state="{ path: 'status', formatter: '.formatter.statusText' }"
                    />
                </statuses>
            </ObjectHeader>

            <Panel headerText="{i18n>ObPgadditionalDetailsHeading}">
                <VBox class="sapUiSmallMargin">
                    <Text text="{i18n>ObPgstartDate}: {
                    path:'startDate',
                    formatter:'.formatter.formatDate'
                    }" />
                    <Text text="{i18n>ObPgendDate}: {
                    path:'endDate',
                    formatter:'.formatter.formatDate'
                    }" />
                    
                 <ObjectStatus
            text="{= ${reason} ? 'Remark: ' + ${reason} : 'Remark: -' }"
            state="{ path: 'status', formatter: '.formatter.statusText' }"
/>
                </VBox>
            </Panel>

        </content>
    </Page>
</mvc:View>