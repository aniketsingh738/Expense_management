{
  "_version": "1.83.0",
  "sap.app": {
    "id": "com.expensemanagement.expensemanagement",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.21.0",
      "toolsId": "51ec0036-eb7c-4886-b7c3-eed9475d68bf"
    }
  },
