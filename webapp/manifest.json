    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "com.expensemanagement.expensemanagement.view",
        "async": true,
        "viewPath": "com.expensemanagement.expensemanagement.view"
      },
      "routes": [
        {
          "name": "dashboard",
          "pattern": ":?query:",
          "target": [
            "TargetView1"
          ]
        },
        {
          "name": "createReq",
          "pattern": "create",
          "target": [
            "createView"
          ]
        },
        {
          "name":"draftRequest",
          "pattern":"draft",
          "target":[
            "draftView"
          ]
        },
        {
          "name":"requestStatus",
          "pattern":"status",
          "target":[
            "statusView"
          ]
        },
        {
          "name":"pendingApproval",
          "pattern":"pending",
          "target":[
            "pendingView"
          ]
        },
        {
          "name":"viewRequest",
          "pattern":"view",
          "target":[
            "viewView"
          ]
        },
        {
          "name":"testRequest",
          "pattern":"test",
          "target":[
            "testView"
          ]
        },
        {
          "name":"objectPage",
           "pattern": "object/{path}",
      "target": "objectPage"
        }
      ],
      "targets": {
        "TargetView1": {
          "id": "View1",
          "name": "View1"
        },
        "createView": {
          "id": "Create",
          "name": "Create"
        },
        "draftView":{
          "id":"Draft",
          "name":"Draft"
        },
        "statusView":{
          "id":"List",
          "name":"List"
        },
        "pendingView":{
          "id":"Pending",
          "name":"Pending"
        },
        "viewView":{
          "id":"Finance",
          "name":"Finance"
        },
        "testView":{
          "id":"Test",
          "name":"Test"
        },
        "objectPage":{
          "id":"Object",
          "name":"Object"
        }
      }
    },
    "rootView": {
      "viewName": "com.expensemanagement.expensemanagement.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  },
  "sap.cloud": {
    "public": true,
    "service": "comexpensemanagementexpensemanagement"
  }
}