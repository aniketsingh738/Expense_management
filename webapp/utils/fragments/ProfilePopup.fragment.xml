<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Popover
        id="profilePopover"
        title="User Info"
        placement="Bottom"
    >
        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="Name: {userModel>/name}" />
                <Text text="Role: {userModel>/role}" />
            </VBox>
        </content>

        <footer>
            <Toolbar>
                <ToolbarSpacer />
                <Button text="Close" press=".onClosePopover" />
            </Toolbar>
        </footer>
    </Popover>

</core:FragmentDefinition>