<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="displayDialog"
        title="{dialogModel>/title}"
        draggable="true"
        resizable="true">

        <content>
            <VBox class="sapUiSmallMargin">
                <Text text="{dialogModel>/message}" />
            </VBox>
        </content>

        <!-- Optional buttons -->
        <beginButton>
            <Button
                text="OK"
                press=".onDialogOk"
                visible="{dialogModel>/showActions}" />
        </beginButton>

        <endButton>
            <Button
                text="Close"
                press=".onDialogCancel"
                />
        </endButton>

    </Dialog>

</core:FragmentDefinition>