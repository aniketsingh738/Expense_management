<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Dialog
        title="Edit Request"
        draggable="true"
        resizable="true"
    >
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Destination" />
                <Input value="{editModel>/destination}" />

                <Label text="Travel Type" />
                <Select selectedKey="{editModel>/travelType}">
                    <items>
                        <core:Item
                            key="Domestic"
                            text="Domestic"
                        />
                        <core:Item
                            key="International"
                            text="International"
                        />
                    </items>
                </Select>
                <Label text="Start Date" />
                <DatePicker
                    value="{editModel>/startDate}"
                    valueFormat="yyyy-MM-dd"
                    displayFormat="dd MMM yyyy"
                />

                <!-- ✅ End Date -->
                <Label text="End Date" />
                <DatePicker
                    value="{editModel>/endDate}"
                    valueFormat="yyyy-MM-dd"
                    displayFormat="dd MMM yyyy"
                />
                <Label text="Amount" />
                <Input
                    value="{editModel>/amount}"
                    type="Number"
                />

                <Label text="Purpose" />
                <TextArea value="{editModel>/purpose}" />
            </VBox>
        </content>

        <beginButton>
            <Button
                text="Save"
                type="Emphasized"
                press=".onSaveEdit"
            />
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onCancelEdit"
            />
        </endButton>
    </Dialog>
</core:FragmentDefinition>
