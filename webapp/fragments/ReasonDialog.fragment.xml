<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        title="{reasonModel>/title}"
        draggable="true"
        resizable="true">

        <content>
            <VBox class="sapUiSmallMargin">

                <Label text="Enter Reason" required="true"/>
                <TextArea
                    value="{reasonModel>/reason}"
                    rows="4"
                    width="100%" />

            </VBox>
        </content>

        <beginButton>
            <Button
                text="OK"
                type="Emphasized"
                press=".onReasonSubmit"/>
        </beginButton>

        <endButton>
            <Button
                text="Cancel"
                press=".onReasonCancel"/>
        </endButton>

    </Dialog>

</core:FragmentDefinition>